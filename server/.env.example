# Copiez ce fichier en ".env" puis redémarrez : npm start
#
# IMPORTANT — Sans SMTP_HOST + MAIL_FROM + MAIL_TO :
# aucun mail n’arrive dans la boîte Vision Boosters. Les messages vont uniquement dans server/data/leads.jsonl

PORT=3001
# SERVE_STATIC=0 désactive la diffusion des fichiers HTML/CSS du dossier parent (nginx s’en charge seul).

# Liste des domaines autorisés à appeler l’API (CORS). Séparés par des virgules.
# CORS_ORIGINS=https://visionboostersagency.com,https://www.visionboostersagency.com

# Limite par IP pour POST /api/contact (fenêtre 15 min)
# RATE_LIMIT_MAX=40

# --- E-mail (SMTP de votre hébergeur ou fournisseur mail : OVH, Infomaniak, Zoho, Google Workspace…) ---
# Gmail perso : compte Google → Sécurité → mot de passe d’application, SMTP smtp.gmail.com:587.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
# Obliger STARTTLS sur le port 587 (essayez si l’envoi échoue)
# SMTP_REQUIRE_TLS=true
# SMTP_VERIFY_ON_START=0 désactive le test SMTP au démarrage du serveur
# SMTP_DEBUG=true traces détaillées dans la console
SMTP_USER=votre_compte_smtp
SMTP_PASS=votre_mot_de_passe
MAIL_FROM="Vision Boosters <noreply@votredomaine.com>"
MAIL_TO=info@visionboostersagency.com
